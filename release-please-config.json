{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "node",
      "package-name": "senior-ponto",
      "include-v-in-tag": true,
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": false,
      "draft": false,
      "prerelease": false,
      "changelog-sections": [
        { "type": "feat", "section": "Novidades", "hidden": false },
        { "type": "fix", "section": "Correções", "hidden": false },
        { "type": "ui", "section": "Mudanças Visuais", "hidden": false },
        { "type": "perf", "section": "Performance", "hidden": false },
        { "type": "a11y", "section": "Acessibilidade", "hidden": false },
        { "type": "revert", "section": "Reversões", "hidden": false },
        { "type": "security", "section": "Segurança", "hidden": true },
        { "type": "refactor", "section": "Refatoração", "hidden": true },
        { "type": "docs", "section": "Documentação", "hidden": true },
        { "type": "test", "section": "Testes", "hidden": true },
        { "type": "build", "section": "Build", "hidden": true },
        { "type": "ci", "section": "CI", "hidden": true },
        { "type": "chore", "section": "Manutenção", "hidden": true },
        { "type": "deps", "section": "Dependências", "hidden": true }
      ]
    }
  }
}
